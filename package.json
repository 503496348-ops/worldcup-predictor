{
  "name": "world-cup-2026-prediction-model",
  "version": "1.0.0",
  "description": "Open-source statistical model (Elo + Dixon-Coles bivariate Poisson + Monte Carlo) for the 2026 FIFA World Cup. Powers the live predictions at cup26matches.com.",
  "type": "module",
  "scripts": {
    "calibrate": "node calibrate.mjs",
    "backtest": "node backtest.mjs",
    "predict": "node predict.mjs",
    "setup": "python3 scripts/setup.py",
    "doctor": "python3 scripts/doctor.py",
    "smoke": "python3 scripts/smoke.py",
    "check:syntax": "python3 -m py_compile scripts/setup.py scripts/doctor.py scripts/smoke.py",
    "test": "python3 -m pytest tests/test_one_click_open_box.py -q"
  },
  "keywords": [
    "world-cup-2026",
    "fifa",
    "football",
    "soccer",
    "predictions",
    "elo",
    "dixon-coles",
    "poisson",
    "monte-carlo",
    "sports-analytics",
    "statistics"
  ],
  "homepage": "https://cup26matches.com",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
